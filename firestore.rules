rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // == Identidad ==
    // "Staff" = sesion REAL (no anonima) que YA tiene su ficha en /usuarios.
    // Antes se usaba solo request.auth != null ("logueado"), lo que dejaba
    // entrar a cualquier sesion anonima (las que crea el formulario publico).
    function noAnonimo() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    function esStaff() {
      return noAnonimo()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }
    function esAdmin() {
      return esStaff()
        && ( get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'Administrador'
          || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin' );
    }
    // Un lead del formulario publico: solo se permite CREAR con esta forma.
    function esLeadWeb() {
      return request.resource.data.estado == 'lead'
        && request.resource.data.origen == 'web';
    }

    // == Usuarios ==
    // Crear la ficha propia SOLO al aceptar una invitacion valida (el email del
    // doc debe coincidir con el de la cuenta, y debe existir una invitacion
    // para ese email). Asi, aunque el registro email/clave este abierto, nadie
    // puede auto-asignarse acceso sin haber sido invitado por un admin.
    match /usuarios/{uid} {
      allow read: if esStaff();
      // Comparaciones de email en minusculas: Firebase Auth normaliza el email
      // del token, pero la invitacion pudo guardarse con mayusculas. Sin .lower()
      // la creacion se denegaba y la cuenta quedaba en Auth sin ficha.
      allow create: if esAdmin()
        || ( noAnonimo()
             && request.auth.uid == uid
             && request.resource.data.email.lower() == request.auth.token.email.lower()
             && request.resource.data.inviteToken is string
             && exists(/databases/$(database)/documents/invitaciones/$(request.resource.data.inviteToken))
             && get(/databases/$(database)/documents/invitaciones/$(request.resource.data.inviteToken)).data.email.lower() == request.auth.token.email.lower() );
      // Editar la ficha propia, pero SIN poder cambiarse el rol uno mismo.
      allow update: if esAdmin()
        || ( noAnonimo()
             && request.auth.uid == uid
             && request.resource.data.rol == resource.data.rol );
      allow delete: if esAdmin();
    }

    // == Invitaciones ==
    // get(): el invitado abre su link (el token es un secreto en la URL).
    // list(): solo staff puede enumerarlas. Crear/borrar: solo admin.
    // update: admin, o el propio invitado SOLO para marcarla como usada al
    // activarse (sin esto la escritura se denegaba, la invitacion quedaba
    // usado:false para siempre y el link seguia siendo reutilizable).
    match /invitaciones/{token} {
      allow get: if true;
      allow list: if esStaff();
      allow create, delete: if esAdmin();
      allow update: if esAdmin()
        || ( noAnonimo()
             && request.auth.token.email.lower() == resource.data.email.lower()
             && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['usado','uid','fechaUso'])
             && request.resource.data.usado == true
             && request.resource.data.uid == request.auth.uid );
    }

    // == Configuracion ==
    match /config/{id} { allow read, write: if esStaff(); }

    // == Clientes ==
    // Lectura y edicion: solo staff. El formulario publico puede CREAR un lead
    // (no leer, no editar, no borrar datos existentes).
    match /clientes/{id} {
      allow read:   if esStaff();
      allow create: if esStaff() || (request.auth != null && esLeadWeb());
      allow update: if esStaff();
      allow delete: if esAdmin();
    }

    // == Resto de colecciones internas: solo staff ==
    match /creditos/{id}          { allow read, create, update: if esStaff(); allow delete: if esAdmin(); }
    match /pagos/{id}             { allow read, create, update: if esStaff(); allow delete: if esAdmin(); }
    match /motos/{id}             { allow read, create, update: if esStaff(); allow delete: if esAdmin(); }
    match /facturas/{id}          { allow read, create, update: if esStaff(); allow delete: if esAdmin(); }
    match /cuentas/{id}           { allow read, create, update: if esStaff(); allow delete: if esAdmin(); }
    match /cuentasPendientes/{id} { allow read, create, update: if esStaff(); allow delete: if esAdmin(); }
    match /movimientos/{id}       { allow read, create, update: if esStaff(); allow delete: if esAdmin(); }
    match /egresos/{id}           { allow read, create, update: if esStaff(); allow delete: if esAdmin(); }
    match /concesionarios/{id}    { allow read, create, update: if esStaff(); allow delete: if esAdmin(); }
    match /tareas/{id}            { allow read, create, update, delete: if esStaff(); }
    match /recursos/{id}          { allow read, create, update, delete: if esStaff(); }
    match /notas_cobranza/{id}    { allow read, create: if esStaff(); allow update, delete: if esAdmin(); }

    match /logs/{id} {
      allow read: if esAdmin();
      allow create: if esStaff();
      allow update, delete: if false;
    }

    // Todo lo demas, bloqueado.
    match /{document=**} { allow read, write: if false; }
  }
}
