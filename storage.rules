rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Antes: cualquier sesión autenticada (incluida la anónima del formulario
    // público) podía leer y escribir TODO el Storage — donde se guardan cédulas,
    // documentos de motos, etc. Ahora sólo el staff real (sesión no anónima con
    // ficha en /usuarios) tiene acceso.
    match /{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.uid));
    }
  }
}
