rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Antes: cualquier sesion autenticada (incluida la anonima del formulario
    // publico) podia leer y escribir TODO el Storage -- donde se guardan cedulas,
    // documentos de motos, etc. Ahora solo el staff real (sesion no anonima con
    // ficha en /usuarios) tiene acceso.
    match /{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.uid));
    }
  }
}
